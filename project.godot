; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

[application]

config/name="santos-driver"
config/description="Jogo top-down estilo GTA 2 ambientado em Santos/SP"
run/main_scene="res://scenes/Main.tscn"
config/version="0.1.0"

[display]

window/size/width=1280
window/size/height=720
window/size/fullscreen=true
window/stretch/mode="2d"
window/stretch/aspect="expand"
window/fullscreen=false
window/resizable=true

[input]

mapa_toggle={
"deadzone": 0.5,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":77,"physical_scancode":0,"unicode":0,"echo":false,"script":null)
 ]
}
atirar={
"deadzone": 0.5,
"events": [  ]
}
roubar={
"deadzone": 0.5,
"events": [  ]
}
acelerar={
"deadzone": 0.5,
"events": [  ]
}
frear={
"deadzone": 0.5,
"events": [  ]
}
virar_esquerda={
"deadzone": 0.5,
"events": [  ]
}
virar_direita={
"deadzone": 0.5,
"events": [  ]
}

[input_devices]

pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=false

[rendering]

quality/2d/use_pixel_snap=true
